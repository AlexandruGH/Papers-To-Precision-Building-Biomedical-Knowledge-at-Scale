# Copy to a `.env` file at the repo root and fill in.
# Loaded by biograph.config.Settings (via python-dotenv if present, else os.environ).

# --- NCBI Entrez (PubMed) ---
# NCBI requires a contact email; an API key raises the rate limit to 10 req/s.
ENTREZ_EMAIL=you@example.org
ENTREZ_API_KEY=

# --- Neo4j (optional; the pipeline defaults to embedded Kuzu) ---
NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# --- Local LLM synthesis via Ollama (no API key) ---
# Start the server (`ollama serve`) and pull a model (`ollama pull qwen3.5:2b`).
# If the server is unreachable, G-Retriever prints the assembled prompt instead.
OLLAMA_BASE_URL=http://localhost:11434/v1
BIOGRAPH_LLM_MODEL=qwen3.5:2b
